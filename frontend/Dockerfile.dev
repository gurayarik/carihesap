FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache bash git python3 make g++ 

COPY package*.json ./
# install deps once at image build (helps caching); we still run npm install at runtime to pick up local changes if needed
RUN npm install --legacy-peer-deps

COPY . .

EXPOSE 4200

CMD ["sh", "-c", "npx ng serve --host 0.0.0.0 --port 4200 --disable-host-check"]
